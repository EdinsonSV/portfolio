---
import { cvData } from '../data/cv';
import { GitBranch, GitCommit } from 'lucide-astro';
import { DateTime } from 'luxon';

const formatPeriod = (startDate: string, endDate: string | null) => {
  const start = DateTime.fromISO(startDate).setLocale('es').toFormat('LLLL yyyy');
  const end = endDate ? DateTime.fromISO(endDate).setLocale('es').toFormat('LLLL yyyy') : 'Actualidad';
  return `${start.charAt(0).toUpperCase() + start.slice(1)} – ${end.charAt(0).toUpperCase() + end.slice(1)}`;
};
---

<section id="experience" class="section">
  <div class="container">
    <h2 class="section-title">Experiencia Laboral</h2>
    
    <div class="timeline">
      <div class="timeline-line"></div>
      
      {cvData.experience.map((job, jobIndex) => (
        <div class="experience-card">
          <div class="timeline-node">
            <GitBranch size={18} />
          </div>
          
          <div class="card-content">
            <div class="card-header">
              <div class="header-main">
                <span class="branch-name">
                  <GitBranch size={14} class="branch-icon" />
                  {job.company.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}
                </span>
                <h3 class="job-role">{job.role}</h3>
              </div>
              <div class="header-meta">
                <span class="company">{job.company}</span>
                <span class="period">{formatPeriod(job.startDate, job.endDate)}</span>
              </div>
            </div>
            
            <div class="commits-section">
              <div class="commits-header">
                <GitCommit size={14} />
                <span>{job.description.length} commits</span>
              </div>
              
              <ul class="commits-list">
                {job.description.map((item, index) => (
                  <li class="commit-item">
                    <div class="commit-hash">{`${(jobIndex + 1).toString().padStart(2, '0')}${(index + 1).toString().padStart(2, '0')}`}</div>
                    <div class="commit-message">{item}</div>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-left: 2rem;
  }

  .timeline-line {
    position: absolute;
    left: 8px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-primary),
      var(--color-secondary),
      var(--color-primary)
    );
    opacity: 0.3;
  }

  .experience-card {
    position: relative;
    display: flex;
    gap: 1.5rem;
  }

  .timeline-node {
    position: absolute;
    left: -2rem;
    top: 1.5rem;
    width: 32px;
    height: 32px;
    background: var(--color-bg);
    border: 2px solid var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    z-index: 2;
    transition: all 0.3s ease;
  }

  .experience-card:hover .timeline-node {
    background: var(--color-primary);
    color: #fff;
    box-shadow: 0 0 20px rgba(4, 116, 192, 0.5);
  }

  .card-content {
    flex: 1;
    background: rgba(18, 18, 18, 0.8);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .experience-card:hover .card-content {
    border-color: var(--color-primary);
    transform: translateX(5px);
  }

  .card-header {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--color-border);
  }

  .header-main {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .branch-name {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-secondary);
    background: rgba(0, 219, 181, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    width: fit-content;
  }

  .branch-icon {
    opacity: 0.7;
  }

  .job-role {
    margin: 0;
    font-size: 1.4rem;
    color: #fff;
  }

  .header-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .company {
    font-weight: 600;
    color: var(--color-text-main);
  }

  .period {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.75rem;
    border-radius: 4px;
    margin-left: auto;
  }

  .commits-section {
    padding: 1.5rem;
  }

  .commits-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
  }

  .commits-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .commit-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 0.5rem;
    border-radius: 6px;
    transition: background 0.2s ease;
  }

  .commit-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .commit-hash {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-primary);
    background: rgba(4, 116, 192, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .commit-message {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .timeline {
      padding-left: 1.5rem;
    }
    
    .timeline-node {
      left: -1.5rem;
      width: 24px;
      height: 24px;
    }

    .period {
      margin-left: 0;
    }
  }
  /* Light Mode Overrides - Vibrant */
  :global(html.light-mode) .card-content {
    background: #ffffff;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08); /* Sombra más definida */
    border: 1px solid #e5e7eb;
  }

  :global(html.light-mode) .experience-card:hover .card-content {
    border-color: var(--color-primary);
    box-shadow: 0 10px 25px rgba(4, 116, 192, 0.2); /* Sombra de color al hover */
  }

  :global(html.light-mode) .job-role {
    color: #111827; /* Negro intenso */
    font-weight: 700;
  }

  :global(html.light-mode) .timeline-node {
    background: #ffffff;
    border-color: #0369a1; /* Azul fuerte */
    box-shadow: 0 0 0 2px rgba(3, 105, 161, 0.1);
  }

  :global(html.light-mode) .experience-card:hover .timeline-node {
    background: #0369a1;
    color: #fff;
    box-shadow: 0 0 15px rgba(3, 105, 161, 0.5); /* Glow intenso */
  }

  :global(html.light-mode) .branch-name {
    background: rgba(4, 116, 192, 0.1);
    color: #0284c7; /* Azul celeste saturado */
    font-weight: 600;
  }

  :global(html.light-mode) .commit-hash {
    background: rgba(236, 72, 153, 0.1); /* Rosa suave */
    color: #db2777; /* Rosa fuerte en lugar de azul default */
  }
</style>
