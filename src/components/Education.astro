---
import { cvData } from '../data/cv';
import { Package, Download, CheckCircle } from 'lucide-astro';
import { DateTime } from 'luxon';

const formatPeriod = (startDate: string, endDate: string | null) => {
  const startYear = DateTime.fromISO(startDate).year.toString();
  const endYear = endDate ? DateTime.fromISO(endDate).year.toString() : 'Actualidad';
  return startYear === endYear ? startYear : `${startYear} – ${endYear}`;
};

const getStartYear = (startDate: string) => {
  return DateTime.fromISO(startDate).year.toString();
};

const calculateTotalYears = () => {
  if (!cvData.education.length) return 0;
  
  const startDates = cvData.education.map(edu => DateTime.fromISO(edu.startDate));
  const minDate = DateTime.min(...startDates);
  
  const endDates = cvData.education.map(edu => edu.endDate ? DateTime.fromISO(edu.endDate) : DateTime.now());
  const maxDate = DateTime.max(...endDates);
  
  if (!minDate || !maxDate) return 0;
  
  return maxDate.year - minDate.year;
};

const totalYears = calculateTotalYears();
---

<section id="education" class="section">
  <div class="container">
    <h2 class="section-title">Educación</h2>
    
    <div class="terminal-window">
      <div class="terminal-header">
        <div class="terminal-tabs">
          <span class="tab active">
            <span class="tab-icon">📦</span>
            npm
          </span>
        </div>
        <span class="terminal-title">C:\Users\edinson\education - npm</span>
        <div class="terminal-actions">
          <span class="action">─</span>
          <span class="action">□</span>
          <span class="action">×</span>
        </div>
      </div>
      
      <div class="terminal-body">
        <div class="command-line">
          <span class="prompt">&gt;</span>
          <span class="command">npm install knowledge --save-dev</span>
        </div>
        
        <div class="packages-list">
          {cvData.education.map((edu, index) => (
            <div class="package-item">
              <div class="package-status">
                <CheckCircle size={16} class="check-icon" />
              </div>
              <div class="package-info">
                <div class="package-header">
                  <Package size={16} class="package-icon" />
                  <span class="package-name">{edu.degree.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}</span>
                  <span class="package-version">@{getStartYear(edu.startDate)}</span>
                </div>
                <div class="package-details">
                  <span class="package-desc">{edu.degree}</span>
                  <span class="package-source">from <span class="source-name">{edu.institution}</span></span>
                </div>
                <div class="package-meta">
                  <span class="location">{edu.location}</span>
                  <span class="date">{formatPeriod(edu.startDate, edu.endDate)}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <div class="install-summary">
          <span class="success-text">✓ added {cvData.education.length} packages</span>
          <span class="time-text">in {totalYears} years</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .terminal-window {
    background: #1e1e1e;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .terminal-header {
    background: #2d2d2d;
    padding: 0;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-tabs {
    display: flex;
  }

  .tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #1e1e1e;
    font-size: 0.85rem;
    color: var(--color-text-main);
    border-right: 1px solid var(--color-border);
  }

  .tab-icon {
    font-size: 0.9rem;
  }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .terminal-actions {
    display: flex;
    gap: 0.25rem;
    padding-right: 1rem; /* Added padding to move them away from the edge */
  }

  .action {
    padding: 0.25rem 0.5rem;
    color: var(--color-text-muted);
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .action:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .action:last-child:hover {
    background: #e81123;
    color: #fff;
  }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: var(--font-mono);
  }

  .command-line {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
  }

  .prompt {
    color: #27c93f;
    font-weight: bold;
  }

  .command {
    color: #fff;
  }

  .packages-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .package-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid transparent;
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .package-item:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--color-primary);
    transform: translateX(5px);
  }

  .package-status {
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  .check-icon {
    color: #27c93f;
  }

  .package-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .package-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .package-icon {
    color: var(--color-secondary);
  }

  .package-name {
    color: var(--color-primary);
    font-weight: 600;
  }

  .package-version {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .package-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .package-desc {
    color: #fff;
    font-size: 0.95rem;
  }

  .package-source {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .source-name {
    color: var(--color-secondary);
  }

  .package-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* Light Mode Text Overrides */
  :global(html.light-mode) .package-desc {
    color: #1f2937; /* Dark Gray */
    font-weight: 500;
  }
  
  :global(html.light-mode) .package-version,
  :global(html.light-mode) .package-source,
  :global(html.light-mode) .location,
  :global(html.light-mode) .date {
    color: #6b7280; /* Gray */
