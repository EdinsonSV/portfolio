      font-size: 0.85rem;
    }

    .package-item {
      flex-direction: column;
      gap: 0.5rem;
    }

    .package-meta {
      flex-direction: column;
      gap: 0.25rem;
    }
    
    .install-summary {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
  /* Light Mode Overrides - Vibrant */
  :global(html.light-mode) .terminal-window {
    background: #ffffff;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15); /* Sombra más fuerte */
    border: 1px solid #e5e7eb;
  }

  :global(html.light-mode) .terminal-header {
    background: #f1f5f9; /* Gris azulado muy suave */
    border-bottom: 1px solid #cbd5e1;
  }

  :global(html.light-mode) .tab {
    background: #f1f5f9; /* Inactive tab bg */
    border-right-color: #cbd5e1;
    color: #64748b;
  }

  :global(html.light-mode) .tab.active {
    background: #ffffff; /* Active tab bg WHITE */
    border-top: 2px solid var(--color-primary); 
    color: #111827;
    font-weight: 700;
  }

  :global(html.light-mode) .package-name {
    color: #0369a1; /* Azul más oscuro y fuerte */
