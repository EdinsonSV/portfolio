  :global(html.light-mode) .source-name {
    color: #0369a1; /* Strong Blue */
  }

  .install-summary {
    display: flex;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(255, 255, 255, 0.1);
    font-size: 0.9rem;
  }

  .success-text {
