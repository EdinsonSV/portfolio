  }

  /* Light Mode Command & Actions */
  :global(html.light-mode) .command {
    color: #111827; /* Dark text for command */
    font-weight: 600;
  }
  
  :global(html.light-mode) .action {
    color: #4b5563; /* Darker icons */
  }

  :global(html.light-mode) .action:hover {
    background: rgba(0, 0, 0, 0.1); /* Dark hover effect */
