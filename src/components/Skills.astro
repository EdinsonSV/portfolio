---
import { cvData } from '../data/cv';
import { AppWindow, Terminal, DatabaseZap, Command, Smartphone } from 'lucide-astro';

const categories = [
  { key: 'mobile', label: 'Mobile', Icon: Smartphone, color: '#61dafb' },
  { key: 'frontend', label: 'Frontend', Icon: AppWindow, color: '#00dbb5' },
  { key: 'backend', label: 'Backend', Icon: Terminal, color: '#0474C0' },
  { key: 'database', label: 'Base de Datos', Icon: DatabaseZap, color: '#ff0055' },
  { key: 'tools', label: 'Herramientas', Icon: Command, color: '#ffbd2e' }
];

---

<section id="skills" class="section">
  <div class="container">
    <h2 class="section-title">Habilidades Técnicas</h2>
    
    <div class="skills-grid">
      {categories.map(({ key, label, Icon, color }) => {
        const skills = cvData.skills[key as keyof typeof cvData.skills];
        
        return (
          <div class="skill-card" style={`--card-color: ${color}`}>
            <div class="card-glow"></div>
            <div class="card-content">
              <div class="card-header">
                <div class="icon-box">
                  <Icon size={28} />
                </div>
                <div class="header-text">
                  <span class="label-prefix">{'// '}</span>
                  <h3>{label}</h3>
                </div>
              </div>
              
              <div class="card-body">
                {key === 'mobile' && (
                  <>
                    <div class="code-block">
                      <span class="code-operator">&lt;</span><span class="code-function">MobileApp</span>
                    </div>
                    <ul class="skills-list" style="padding-left: 1.5rem;">
                      {skills.map((skill) => (
                        <li class="skill-item">
                          <span class="code-operator">&nbsp;&nbsp;</span>
                          <span class="code-key">{skill.toLowerCase().replace(' ', '-')}</span>
                          <span class="code-operator">=</span>
                          <span class="code-keyword">{'{'}</span>
                          <span class="code-type">true</span>
                          <span class="code-keyword">{'}'}</span>
                        </li>
                      ))}
                    </ul>
                    <div class="code-block">
                      <span class="code-operator">/&gt;</span>
                    </div>
                  </>
                )}

                {key === 'frontend' && (
                  <>
                    <div class="code-block">
                      <span class="code-keyword">const</span> frontend <span class="code-operator">=</span> [
                    </div>
                    <ul class="skills-list">
                      {skills.map((skill, index) => (
                        <li class="skill-item">
                          <span class="skill-string">"{skill}"</span>
                          {index < skills.length - 1 && <span class="comma">,</span>}
                        </li>
                      ))}
                    </ul>
                    <div class="code-block">];</div>
                  </>
                )}

                {key === 'backend' && (
                  <>
                    <div class="code-block">
                      <span class="code-keyword">class</span> Backend <span class="code-keyword">extends</span> <span class="code-type">Developer</span> {'{'}
                    </div>
                    <div class="skills-list" style="padding-left: 1.5rem;">
                      <div class="code-block">
                        <span class="code-keyword">public</span> stack <span class="code-operator">=</span> [
                      </div>
                      <ul class="skills-list" style="padding-left: 1.5rem; margin: 0;">
                        {skills.map((skill, index) => (
                          <li class="skill-item">
                            <span class="skill-string">'{skill}'</span>
                            {index < skills.length - 1 && <span class="comma">,</span>}
                          </li>
                        ))}
                      </ul>
                      <div class="code-block">];</div>
                    </div>
                    <div class="code-block">{'}'}</div>
                  </>
                )}

                {key === 'database' && (
                  <>
                    <div class="code-block">
                      <span class="sql-keyword">INSERT INTO</span> knowledge (
                    </div>
                    <ul class="skills-list">
                      {skills.map((skill, index) => (
                        <li class="skill-item">
                          <span class="skill-string">'{skill}'</span>
                          {index < skills.length - 1 && <span class="comma">,</span>}
                        </li>
                      ))}
                    </ul>
                    <div class="code-block">);</div>
                  </>
                )}

                {key === 'tools' && (
                  <>
                    <div class="code-block">
                      <span class="code-comment"># dev-tools.yml</span>
                    </div>
                    <div class="code-block">
                      <span class="code-key">environment:</span>
                    </div>
                    <ul class="skills-list">
                      {skills.map((skill) => (
                        <li class="skill-item">
                          <span class="code-operator">-</span> <span class="skill-string">{skill}</span>
                        </li>
                      ))}
                    </ul>
                  </>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .skill-card {
    position: relative;
    background: rgba(18, 18, 18, 0.8);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .skill-card:hover {
    transform: translateY(-5px);
    border-color: var(--card-color);
  }

  /* Glow effect on hover */
  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    background: radial-gradient(
      circle at 50% 0%,
      color-mix(in srgb, var(--card-color) 15%, transparent),
      transparent 70%
    );
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .skill-card:hover .card-glow {
    opacity: 1;
  }

  .card-content {
    position: relative;
    z-index: 1;
    padding: 1.5rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .icon-box {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--card-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-color) 30%, transparent);
    border-radius: 10px;
    color: var(--card-color);
    transition: all 0.3s ease;
  }

  .skill-card:hover .icon-box {
    background: var(--card-color);
    color: #000;
    box-shadow: 0 0 20px color-mix(in srgb, var(--card-color) 50%, transparent);
  }

  .header-text {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem;
  }

  .label-prefix {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .header-text h3 {
    margin: 0;
    font-size: 1.3rem;
    color: #fff;
  }

  /* Code-style body */
  .card-body {
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .code-block {
    color: var(--color-text-muted);
  }

  .code-keyword {
    color: #c678dd;
  }

  .code-operator {
    color: #56b6c2;
  }

  .skills-list {
    padding-left: 1.5rem;
    margin: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .skill-item:hover {
    transform: translateX(5px);
  }

  .skill-string {
    color: #98c379;
    transition: text-shadow 0.2s ease;
  }

  .skill-item:hover .skill-string {
    text-shadow: 0 0 10px rgba(152, 195, 121, 0.5);
  }

  .comma {
    color: var(--color-text-muted);
  }
  .code-type {
    color: #e5c07b;
  }

  .code-comment {
    color: #5c6370;
    font-style: italic;
  }

  .code-key {
    color: #e06c75;
  }

  .code-function {
    color: #61afef;
  }

  .sql-keyword {
    color: #c678dd;
    font-weight: bold;
  }
  /* Light Mode Overrides Enhancements */
  :global(html.light-mode) .skill-card {
    background: #ffffff;
    /* Sombra de color sutil basada en la tarjeta pero visible */
    box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  :global(html.light-mode) .skill-card:hover {
    /* Glow de color más intenso en hover */
    box-shadow: 0 20px 40px -10px var(--card-color), 0 0 0 1px var(--card-color);
  }

  :global(html.light-mode) .header-text h3 {
    color: #111827;
    font-weight: 800;
  }

  :global(html.light-mode) .card-header {
    border-bottom: 2px solid rgba(0, 0, 0, 0.05); /* Borde un poco más grueso */
  }

  :global(html.light-mode) .icon-box {
    background: rgba(0, 0, 0, 0.03); /* Fondo gris muy suave para el icono */
    border-color: rgba(0,0,0,0.1);
  }

  /* High Contrast / Vivid Syntax Highlighting for Light Mode */
  :global(html.light-mode) .code-keyword { color: #d00b90; font-weight: 600; } /* Magenta fuerte */
  :global(html.light-mode) .code-function { color: #005cc5; font-weight: 600; } /* Azul intenso */
  :global(html.light-mode) .code-string, 
  :global(html.light-mode) .skill-string { color: #22863a; font-weight: 500; } /* Verde bosque */
  :global(html.light-mode) .code-type { color: #b05a00; font-weight: 600; } /* Naranja quemado */
  :global(html.light-mode) .code-operator { color: #005cc5; font-weight: bold; }
  :global(html.light-mode) .code-key { color: #e3116c; font-weight: 600; } /* Rojo/Rosa fuerte */
  :global(html.light-mode) .sql-keyword { color: #d00b90; font-weight: 700; }
  :global(html.light-mode) .comma { color: #111827; font-weight: bold; }
  
  :global(html.light-mode) .skill-item:hover .skill-string {
    text-shadow: 0 0 15px rgba(34, 134, 58, 0.4); /* Glow verde sutil */
    transform: translateX(5px) scale(1.02);
  }
</style>
